      },
      {
        "key": "cargo",
        "type": "string",
        "ai": "Cargo o función del trabajador. En instituciones militares puede aparecer como rango/grado antes del nombre (ej: CAP.=Capitán, SGT.=Sargento, TTE.=Teniente). Extrae el cargo completo."
      },
      {
        "key": "fecha_ingreso",
