  "avaluo-fiscal": {
    "label": "Avalúo Fiscal",
    "shortLabel": "Avalúo",
    "source": "SII",
    "category": "activos",
    "freq": "once",
    "count": 1,
    "multiInstance": true,
    "definition": "Certificado de Avalúo Fiscal emitido exclusivamente por el SII.",
    "classifier": {
      "useWhen": [
        "certificado SII de avalúo fiscal — UN SOLO documento que cubre todas sus páginas, aunque liste una propiedad distinta por página"
      ],
      "signals": [
        "logo SII arriba-izquierda + título centrado 'CERTIFICADO DE AVALÚO FISCAL' (ambos OBLIGATORIOS)",
        "campos: Comuna, Número de ROL de Avalúo, Dirección, Destino del bien raíz, Registrado a Nombre de + RUN/RUT",
        "filas AVALÚO TOTAL / AVALÚO EXENTO DE IMPUESTO / AVALÚO AFECTO A IMPUESTO; pie gris 'CERTIFICADO GRATUITO'"
      ],
      "rejectWhen": [
        "escritura de compraventa, certificado de dominio, tasación comercial"
      ],
      "tieBreaker": [
        {
          "vs": "carton-ds1",
          "rule": "avalúo = logo SII + ROL + tasación; DS1 = membrete MINVU + subsidio habitacional"
        },
        {
          "vs": "compraventa-propiedad",
          "rule": "avalúo = logo SII + título 'CERTIFICADO DE AVALÚO FISCAL' + ROL; compraventa = escritura notarial con cláusulas y precio de venta"
        }
      ]
    },
    "dateHint": "Usa la fecha de emisión del certificado",
    "fields": [
      {
        "key": "propiedades",
        "type": "list",
        "ai": "Extrae TODAS las propiedades del certificado como array (una por página). Cada entrada tiene: rol (string, Número de ROL de Avalúo formato XXXXX-XXXXX), direccion (string, dirección completa), comuna (string), destino (string, ej: Habitacional, Estacionamiento, Bodega y Almacenaje, Comercial, Agrícola), nombre_registrado (string, nombre completo del propietario registrado), run_registrado (string, RUN o RUT registrado con dígito verificador), porcentaje_derecho (number, % de derecho como número ej: 100 para 100%), avaluo_total (number, avalúo total en pesos como entero sin separadores), avaluo_exento (number, avalúo exento de impuesto en pesos), avaluo_afecto (number, avalúo afecto a impuesto en pesos)"
      }
    ],
    "howToObtain": {
      "steps": [
        "Ingresa a <a href='https://www.sii.cl' target='_blank' rel='noopener'>www.sii.cl</a>",
        "Haz clic en <b>Servicios Online</b> → <b>Avalúos y Contribuciones de Bienes Raíces</b>",
        "Inicia sesión con tu ClaveÚnica o Clave SII",
        "Selecciona <b>Consulta de Avalúo y Certificado</b>",
        "Se listarán todas tus propiedades. Haz clic en <b>Certificado</b> para descargar el PDF"
      ],
      "tips": [
        "El certificado incluye todas las propiedades registradas a tu nombre",
        "Tiene validez de 30 días desde su emisión",
        "El avalúo fiscal NO corresponde a una tasación comercial"
      ]
    }
  },
