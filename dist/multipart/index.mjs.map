  "cedula-identidad": {
    "label": "Cédula de Identidad",
    "shortLabel": "Carnet",
    "source": "Registro Civil",
    "category": "personal",
    "freq": "once",
    "count": 1,
    "parts": [
      "Frente",
      "Revés"
    ],
    "extractScope": "firstPage",
    "definition": "Cédula de Identidad chilena del Registro Civil — tarjeta plastificada con foto.",
    "classifier": {
      "useWhen": [
        "tarjeta plástica de identidad chilena, frente y/o reverso"
      ],
      "signals": [
        "frente: rótulo 'CÉDULA DE IDENTIDAD', foto, bandera chilena, 'RUN ...' abajo a la izquierda",
        "reverso: huella dactilar, código QR, líneas MRZ 'IDCHL...'"
      ],
      "rejectWhen": [
        "es pasaporte, licencia de conducir u otra credencial"
      ],
      "tieBreaker": []
    },
    "dateHint": "Usa la fecha de emisión de la cédula. Debe coincidir con el campo `fecha_emision`. De las múltiples fechas impresas (nacimiento, emisión, vencimiento) es la INTERMEDIA cronológicamente: posterior a fecha de nacimiento y anterior a fecha de vencimiento. Etiqueta típica: 'FECHA DE EMISIÓN' o 'EMISIÓN'. Si no la encuentras etiquetada pero ves una fecha de vencimiento, la emisión es 4 años antes (cédulas chilenas y de residentes extranjeros tienen validez de 4 años).",
    "fields": [
      {
        "key": "rut",
        "type": "string",
        "ai": "RUN chileno impreso al pie de la cédula como 'RUN 26.621.198-8' (frente) y también en la última línea del MRZ del reverso (ej. 'VEN26621198<8<0' → 26621198-8). Formato XX.XXX.XXX-X o XX.XXX.XXX-K. El dígito verificador al final puede ser 0-9 o K, NUNCA 'B' (si lees 'B' es un '8' mal reconocido). No lo confundas con 'NÚMERO DOCUMENTO' (otro campo distinto) ni con la fecha de nacimiento del MRZ. Si aparece en ambos lados, cópialo del frente."
      },
      {
        "key": "nombres",
        "type": "string"
      },
      {
        "key": "apellidos",
        "type": "string"
      },
      {
        "key": "nacionalidad",
        "type": "string",
        "ai": "Valor literal del campo 'NACIONALIDAD' en el frente de la cédula. En cédulas de extranjeros es el código ISO de 3 letras del país de origen (VEN, PER, COL, ARG, BOL, ECU, HTI, CHN, etc.). En cédulas chilenas es 'CHILENA' o 'CHL'. NUNCA devuelvas 'EXTRANJERO' — esa palabra es el tipo de cédula (título en el encabezado), no la nacionalidad."
      },
      {
        "key": "sexo",
        "type": "string",
        "internal": true,
        "ai": "Una sola letra: 'M' (masculino) o 'F' (femenino). Nunca devuelvas el código de nacionalidad ni otro valor — si no lees claramente M o F, devuelve null."
      },
      {
        "key": "fecha_nacimiento",
        "type": "date"
      },
      {
        "key": "numero_documento",
        "type": "string",
        "internal": true,
        "ai": "Número del documento de origen impreso en el frente como 'NÚMERO DOCUMENTO' (ej. '603.113.124'). Solo en cédulas de extranjeros. NO es el RUN, NO es el MRZ del reverso. Si no existe el campo, devuelve null."
      },
      {
        "key": "fecha_emision",
        "type": "date",
        "internal": true
      },
      {
        "key": "fecha_vencimiento",
        "type": "date",
        "internal": true
      },
      {
        "key": "lugar_nacimiento",
        "type": "string",
        "internal": true,
        "ai": "Texto tal cual aparece después de 'Nació en:' en el reverso de la cédula. Cópialo literal sin interpretar — puede ser una sola palabra (comuna), o varios términos separados por coma (barrio/localidad, comuna). Ejemplos válidos: 'PUENTE ALTO', 'FRANKLIN, SANTIAGO', 'ISLUGA, COLCHANE'"
      },
      {
        "key": "profesion",
        "type": "string",
        "internal": true
      }
    ],
    "howToObtain": {
      "steps": [
        "Toma una foto clara de tu cédula de identidad por ambos lados",
        "Asegúrate que se vean todos los datos sin reflejos",
        "Sube el <b>frente</b> y el <b>revés</b> por separado"
      ],
      "tips": [
        "Usa buena iluminación para evitar sombras",
        "Coloca la cédula sobre un fondo oscuro para mejor contraste"
      ]
    }
  },
  "cert-nacimiento-hijo": {
